{
  "name": "ham-net-logger",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "build:prod": "ng build --configuration production",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "lint": "ng lint",
    "test:rules": "firebase emulators:exec --only firestore \"vitest run tests/firestore.rules.test.ts\"",
    "e2e": "playwright test --project=e2e",
    "e2e:training": "playwright test --project=training-videos",
    "e2e:ui": "playwright test --ui",
    "emulators": "firebase emulators:start",
    "emulators:export": "firebase emulators:export ./emulator-data",
    "emulators:import": "firebase emulators:start --import=./emulator-data",
    "seed": "FIRESTORE_EMULATOR_HOST=localhost:8080 FIREBASE_AUTH_EMULATOR_HOST=localhost:9099 tsx seed/seed-users.ts",
    "seed:prod": "tsx seed/seed-users.ts --confirm-production",
    "dev": "concurrently \"npm run emulators\" \"npm run start\""
  },
  "private": true,
  "packageManager": "npm@10.9.8",
  "dependencies": {
    "@angular/animations": "^20.1.8",
    "@angular/cdk": "^22.0.2",
    "@angular/common": "^22.0.0",
    "@angular/compiler": "^22.0.0",
    "@angular/core": "^22.0.0",
    "@angular/fire": "^20.0.1",
    "@angular/forms": "^22.0.0",
    "@angular/material": "^22.0.2",
    "@angular/platform-browser": "^22.0.0",
    "@angular/router": "^22.0.0",
    "@angular/service-worker": "^22.0.0",
    "ag-grid-angular": "^36.0.0",
    "ag-grid-community": "^36.0.0",
    "file-saver": "^2.0.5",
    "firebase": "^12.15.0",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.8",
    "jszip": "^3.10.1",
    "papaparse": "^5.5.4",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular-eslint/builder": "^22.0.0",
    "@angular-eslint/eslint-plugin": "^22.0.0",
    "@angular-eslint/eslint-plugin-template": "^22.0.0",
    "@angular-eslint/schematics": "^22.0.0",
    "@angular-eslint/template-parser": "^22.0.0",
    "@angular/build": "^22.0.4",
    "@angular/cli": "^22.0.4",
    "@angular/compiler-cli": "^22.0.0",
    "@eslint/js": "^10.0.1",
    "@firebase/rules-unit-testing": "^5.0.1",
    "@playwright/test": "^1.61.1",
    "@types/file-saver": "^2.0.7",
    "@types/papaparse": "^5.5.2",
    "angular-eslint": "^22.0.0",
    "concurrently": "^10.0.3",
    "eslint": "^10.5.0",
    "firebase-admin": "^14.1.0",
    "firebase-tools": "^15.22.3",
    "jsdom": "^28.0.0",
    "prettier": "^3.8.1",
    "tsx": "^4.22.4",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.62.0",
    "vitest": "^4.0.8"
  }
}
