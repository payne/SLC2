rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ============================================
    // Helper Functions
    // ============================================

    // Check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Get user document
    function getUserDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // Check if user has a user document (is authorized)
    function isAuthorized() {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    // Check if user is an inviter or higher
    function isInviter() {
      return isAuthorized() && getUserDoc().level == 'inviter';
    }

    // Check if user is a root admin
    function isRoot() {
      return isAuthorized() && getUserDoc().root == true;
    }

    // Get net document
    function getNetDoc(netId) {
      return get(/databases/$(database)/documents/nets/$(netId)).data;
    }

    // Check if user is NCS or backup for a net
    function isNetWriter(netId) {
      let net = getNetDoc(netId);
      return request.auth.uid == net.ncs || request.auth.uid == net.backupNcs;
    }

    // Check if user is a member of a net
    function isNetMember(netId) {
      return exists(/databases/$(database)/documents/nets/$(netId)/members/$(request.auth.uid));
    }

    // ============================================
    // Users Collection
    // ============================================
    match /users/{uid} {
      // Users can read their own document; inviters can read all for admin
      allow read: if isAuthenticated() &&
        (request.auth.uid == uid || isInviter());

      // Users are created via invitation claim flow
      // Requires: matching pending invitation exists for this email
      allow create: if isAuthenticated() &&
        request.auth.uid == uid &&
        request.resource.data.email == request.auth.token.email.lower() &&
        exists(/databases/$(database)/documents/invitations/$(request.auth.token.email.lower())) &&
        get(/databases/$(database)/documents/invitations/$(request.auth.token.email.lower())).data.status == 'pending';

      // Inviters can promote operators to inviter
      allow update: if isInviter() &&
        request.resource.data.level == 'inviter' &&
        resource.data.level == 'operator' &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['level', 'promotedBy', 'promotedAt']);

      // Root can demote inviters to operators
      allow update: if isRoot() &&
        resource.data.root != true &&
        request.resource.data.level == 'operator' &&
        resource.data.level == 'inviter' &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['level', 'promotedBy', 'promotedAt']);

      // Root can delete non-root users
      allow delete: if isRoot() && resource.data.root != true;
    }

    // ============================================
    // Invitations Collection
    // ============================================
    match /invitations/{email} {
      // Users can read their own pending invitation for claim flow
      allow read: if isAuthenticated() &&
        request.auth.token.email.lower() == email;

      // Inviters can read all invitations for admin
      allow read: if isInviter();

      // Inviters can create invitations
      allow create: if isInviter() &&
        request.resource.data.status == 'pending' &&
        request.resource.data.invitedBy == request.auth.uid &&
        request.resource.data.email == email;

      // Update for claim flow (by the invited user)
      allow update: if isAuthenticated() &&
        request.auth.token.email.lower() == email &&
        resource.data.status == 'pending' &&
        request.resource.data.status == 'claimed' &&
        request.resource.data.claimedBy == request.auth.uid &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'claimedAt', 'claimedBy']);

      // Revoke by inviter (own invitations) or root (any)
      allow update: if (
          (isInviter() && resource.data.invitedBy == request.auth.uid) ||
          isRoot()
        ) &&
        resource.data.status == 'pending' &&
        request.resource.data.status == 'revoked' &&
        request.resource.data.revokedBy == request.auth.uid &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'revokedAt', 'revokedBy']);
    }

    // ============================================
    // People Collection (Roster)
    // ============================================
    match /people/{callsign} {
      // All authorized users can read roster
      allow read: if isAuthorized();

      // Inviters can write to roster (Phase 2 will add more granular rules)
      allow write: if isInviter();
    }

    // ============================================
    // Nets Collection
    // ============================================
    match /nets/{netId} {
      // All authorized users can read nets
      allow read: if isAuthorized();

      // Inviters can create nets
      allow create: if isInviter() &&
        request.resource.data.createdBy == request.auth.uid &&
        request.resource.data.ncs == request.auth.uid &&
        request.resource.data.status == 'active';

      // NCS or backup can update net details
      allow update: if isAuthorized() && isNetWriter(netId);

      // ----------------------------------------
      // Check-ins Subcollection
      // ----------------------------------------
      match /checkins/{checkinId} {
        // Net members can read check-ins
        allow read: if isAuthorized() && isNetMember(netId);

        // NCS or backup can create/update check-ins
        allow create: if isAuthorized() && isNetWriter(netId) &&
          request.resource.data.createdBy == request.auth.uid;

        allow update: if isAuthorized() && isNetWriter(netId);

        // No deletes allowed
        allow delete: if false;
      }

      // ----------------------------------------
      // Members Subcollection
      // ----------------------------------------
      match /members/{uid} {
        // All authorized users can read members
        allow read: if isAuthorized();

        // Users can add themselves as members if they have the correct join code
        // Note: Code validation happens client-side; the rule just ensures
        // the user can only create their own membership
        allow create: if isAuthenticated() &&
          request.auth.uid == uid &&
          getNetDoc(netId).status == 'active';

        // No updates or deletes
        allow update, delete: if false;
      }

      // ----------------------------------------
      // Presence Subcollection
      // ----------------------------------------
      match /presence/{uid} {
        // All authorized users can read presence
        allow read: if isAuthorized();

        // Users can only write their own presence
        allow write: if isAuthenticated() && request.auth.uid == uid;
      }
    }

    // ============================================
    // Config Collection
    // ============================================
    match /config/{docId} {
      // All authorized users can read config
      allow read: if isAuthorized();

      // Inviters can update config
      allow write: if isInviter();
    }

    // ============================================
    // Audit Log Collection (Append-Only)
    // ============================================
    match /auditLog/{eventId} {
      // Only root can read audit log
      allow read: if isRoot();

      // Authorized users can append audit events
      allow create: if isAuthorized() &&
        request.resource.data.actorUid == request.auth.uid &&
        request.resource.data.timestamp == request.time;

      // No updates or deletes
      allow update, delete: if false;
    }
  }
}
