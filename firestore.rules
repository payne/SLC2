rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Deny all access by default
    match /{document=**} {
      allow read, write: if false;
    }

    // Users collection - invite-only access
    // Users can read their own document; admins can read all
    match /users/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false; // Only via admin SDK or specific invite flow (Phase 1)
    }

    // Invitations collection - managed by inviters
    match /invitations/{email} {
      allow read: if false; // Will be opened for claim flow in Phase 1
      allow write: if false; // Will be opened for inviters in Phase 1
    }

    // People collection (roster)
    match /people/{callsign} {
      allow read: if request.auth != null;
      allow write: if false; // Will be opened for authorized users in Phase 2
    }

    // Nets collection
    match /nets/{netId} {
      allow read: if request.auth != null;
      allow write: if false; // Will be opened for NCS/backup in Phase 3

      // Check-ins subcollection
      match /checkins/{checkinId} {
        allow read: if request.auth != null;
        allow write: if false; // Will be opened for NCS/backup in Phase 3
      }

      // Members subcollection
      match /members/{uid} {
        allow read: if request.auth != null;
        allow write: if false; // Will be opened for join flow in Phase 1
      }

      // Presence subcollection
      match /presence/{uid} {
        allow read: if request.auth != null;
        allow write: if request.auth != null && request.auth.uid == uid;
      }
    }

    // Config collection
    match /config/{docId} {
      allow read: if request.auth != null;
      allow write: if false; // Will be opened for inviters/root in Phase 2
    }

    // Audit log - append only
    match /auditLog/{eventId} {
      allow read: if false; // Admin only via console/SDK
      allow write: if false; // Will be opened as append-only in Phase 1
    }
  }
}
